{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Database=issueboard;Username=postgres;Password=root"
  },
  "Jwt": {
    "Issuer": "IssueBoard",
    "Audience": "IssueBoard.Client",
    "SigningKey": "CHANGE_ME_SUPER_SECRET_DEVELOPMENT_KEY_1234567890",
    "ExpirationMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
